# Python
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/

# Virtual env
.venv/

# Test / tooling caches
.pytest_cache/
.mypy_cache/

# Generated outputs (ignore contents, but keep the committed validation matrix).
